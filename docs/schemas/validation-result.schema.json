{
  "$defs": {
    "ValidationIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "object_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Object Name"
        },
        "relative_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Relative Path"
        },
        "remediation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remediation"
        },
        "severity": {
          "enum": [
            "error",
            "warning"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "ValidationIssue",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "checked_paths": {
      "items": {
        "type": "string"
      },
      "title": "Checked Paths",
      "type": "array"
    },
    "command": {
      "const": "validate",
      "default": "validate",
      "title": "Command",
      "type": "string"
    },
    "generated_at_utc": {
      "title": "Generated At Utc",
      "type": "string"
    },
    "issue_count": {
      "title": "Issue Count",
      "type": "integer"
    },
    "issues": {
      "items": {
        "$ref": "#/$defs/ValidationIssue"
      },
      "title": "Issues",
      "type": "array"
    },
    "passed": {
      "title": "Passed",
      "type": "boolean"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_manifest_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Manifest Path"
    },
    "status": {
      "enum": [
        "ok",
        "warning",
        "error"
      ],
      "title": "Status",
      "type": "string"
    },
    "tool_version": {
      "default": "0.1.0",
      "title": "Tool Version",
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "status",
    "passed",
    "issue_count",
    "issues",
    "checked_paths"
  ],
  "title": "ValidationResult",
  "type": "object"
}
